{
  "_author": "MuhammadUsmanGM",
  "_sig": "MUGM-a3f7-9c2b",
  "name": "ferrumdb",
  "version": "0.2.0",
  "description": "A premium, high-performance embedded key-value database with TTL, encryption, and secondary indexes.",
  "main": "index.js",
  "types": "index.d.ts",
  "scripts": {
    "build": "napi build --release --platform",
    "build:debug": "napi build --platform",
    "test": "node --test __test__/test.mjs"
  },
  "napi": {
    "name": "ferrumdb",
    "triples": {
      "defaults": false,
      "additional": [
        "x86_64-unknown-linux-gnu",
        "x86_64-pc-windows-msvc"
      ]
    }
  },
  "keywords": [
    "database",
    "kv",
    "storage",
    "embeddable",
    "json",
    "key-value"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MuhammadUsmanGM/FerrumDB",
    "directory": "ferrumdb-node"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2"
  },
  "optionalDependencies": {
    "ferrumdb-linux-x64-gnu": "0.1.6",
    "ferrumdb-win32-x64-msvc": "0.1.6"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "README.md"
  ]
}
